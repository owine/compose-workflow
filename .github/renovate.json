{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "on monday"
  ],
  "automergeSchedule": [
    "at any time"
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Group all non-major updates into a single PR",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin"
      ],
      "groupName": "all non-major dependencies",
      "automerge": true,
      "ignoreTests": true
    },
    {
      "description": "Major updates - separate PRs for review",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Docker-compose - disable digest pinning",
      "matchManagers": [
        "docker-compose"
      ],
      "pinDigests": false
    }
  ]
}
