{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for Docker Compose repositories",
  "extends": [
    "config:best-practices",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "timezone": "America/Chicago",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "automergeType": "branch",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "{{#if isDigest}}digest to {{newDigestShort}}{{else}}to {{#if isMajor}}{{prettyNewMajor}}{{else}}{{prettyNewVersion}}{{/if}}{{/if}}",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "dependencies"
    ],
    "automerge": true
  },
  "packageRules": [
    {
      "groupName": "All dependencies",
      "groupSlug": "all-deps",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "minimumReleaseAge": "1 hour"
    },
    {
      "groupName": "Major dependencies",
      "groupSlug": "all-deps-major",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": true,
      "minimumReleaseAge": "3 days"
    }
  ]
}
